# ===========================================
# IC Student Portal - Environment Configuration
# ===========================================
# Copy this file to .env and update the values

# API Configuration
# -----------------
# Backend API base URL (leave empty for Vite proxy in development)
VITE_API_BASE_URL=https://dnsc-systems-api.onrender.com

# Application Settings
# --------------------
VITE_APP_NAME=Student Portal

# Google OAuth Configuration
# --------------------------
# Required for "Sign in with Google" functionality
# Get your client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# External Systems
# ----------------
# URL for the Collection Management System
VITE_CMS_URL=https://collection-management-system-one.vercel.app/
# URL for the Voting System
VITE_VOTING_URL=http://localhost:5175
# URL for the Locker System
VITE_LOCKER_URL=https://dnsclocker.vercel.app/
